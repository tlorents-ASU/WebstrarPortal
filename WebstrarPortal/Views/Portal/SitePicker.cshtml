@{
    ViewData["Title"] = "Select a Site";
    var asurite = ViewBag.Asurite as string;
    var sites = ViewBag.Sites as List<int>;
    var showInstructor = ViewBag.ShowInstructorDashboard as bool? ?? false;
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body text-center">
                <h3 class="card-title mb-3">Select a Site</h3>
                <p class="text-muted">
                    Logged in as <strong>@asurite</strong> &mdash; you have access to multiple sites.
                </p>
                <div class="d-grid gap-3 mt-4">
                    @if (showInstructor)
                    {
                        <a href="/instructor" class="btn btn-lg" style="background-color: #8C1D40; color: white;">
                            Instructor Dashboard
                        </a>
                    }
                    @foreach (var siteNum in sites)
                    {
                        <a href="/portal?site=@siteNum" class="btn btn-lg" style="background-color: #FFC627; color: black;">
                            website@(siteNum)
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
