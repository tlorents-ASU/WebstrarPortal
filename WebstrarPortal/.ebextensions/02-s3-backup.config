files:
  "c:\\ebscripts\\sync-to-s3.ps1":
    content: |
      $ErrorActionPreference = "Stop"
      $source = "C:\WebstrarDeploy"
      $bucket = "webstrar-student-backups"
      $region = "us-west-2"
      $logFile = Join-Path $source "_backup_log.txt"

      function Log($msg) {
        $ts = (Get-Date).ToString("s")
        Add-Content -Path $logFile -Value "$ts  $msg"
      }

      try {
        Import-Module AWSPowerShell.NetCore -ErrorAction SilentlyContinue
        if (-not (Get-Module AWSPowerShell* -ErrorAction SilentlyContinue)) {
          Import-Module AWSPowerShell -ErrorAction Stop
        }

        if (-not (Test-Path $source)) {
          Log "Source directory $source does not exist. Skipping."
          exit 0
        }

        $files = Get-ChildItem -Path $source -Recurse -File -ErrorAction SilentlyContinue
        $fileCount = ($files | Measure-Object).Count
        Log "Found $fileCount files in $source"

        if ($fileCount -eq 0) {
          Log "No files to sync. Skipping."
          exit 0
        }

        # Get existing S3 objects for comparison
        $s3Objects = @{}
        $existing = Get-S3Object -BucketName $bucket -KeyPrefix "WebstrarDeploy/" -Region $region
        foreach ($obj in $existing) {
          $s3Objects[$obj.Key] = $obj.LastModified
        }

        $uploaded = 0
        $skipped = 0
        $unchanged = 0
        foreach ($file in $files) {
          $relativePath = $file.FullName.Substring($source.Length + 1).Replace("\", "/")
          if ($relativePath.StartsWith("_") -or $relativePath.EndsWith(".log") -or $relativePath.EndsWith(".tmp")) {
            $skipped++
            continue
          }
          $key = "WebstrarDeploy/$relativePath"
          # Only upload if file is new or modified since last S3 upload
          if ($s3Objects.ContainsKey($key) -and $file.LastWriteTimeUtc -le $s3Objects[$key].ToUniversalTime()) {
            $unchanged++
            continue
          }
          Write-S3Object -BucketName $bucket -Key $key -File $file.FullName -Region $region | Out-Null
          $uploaded++
        }
        Log "Sync complete. Uploaded: $uploaded, Unchanged: $unchanged, Skipped: $skipped"
      }
      catch {
        Log "ERROR: $($_.Exception.Message)"
        Log "Stack: $($_.ScriptStackTrace)"
      }

  "c:\\ebscripts\\restore-from-s3.ps1":
    content: |
      $ErrorActionPreference = "Stop"
      $dest = "C:\WebstrarDeploy"
      $bucket = "webstrar-student-backups"
      $region = "us-west-2"

      Import-Module AWSPowerShell.NetCore -ErrorAction SilentlyContinue
      if (-not (Get-Module AWSPowerShell* -ErrorAction SilentlyContinue)) {
        Import-Module AWSPowerShell -ErrorAction Stop
      }

      Write-Host "Restoring from S3..."
      New-Item -ItemType Directory -Force -Path $dest | Out-Null

      $objects = Get-S3Object -BucketName $bucket -KeyPrefix "WebstrarDeploy/" -Region $region
      foreach ($obj in $objects) {
        if ($obj.Key.EndsWith("/")) { continue }
        $relativePath = $obj.Key.Substring("WebstrarDeploy/".Length)
        $localPath = Join-Path $dest $relativePath.Replace("/", "\")
        $dir = Split-Path $localPath -Parent
        New-Item -ItemType Directory -Force -Path $dir | Out-Null
        Read-S3Object -BucketName $bucket -Key $obj.Key -File $localPath -Region $region | Out-Null
      }
      Write-Host "Restore complete. Downloaded $($objects.Count) objects."

  "c:\\ebscripts\\setup-s3-backup-task.ps1":
    content: |
      $ErrorActionPreference = "Stop"
      $taskName = "WebstrarS3Backup"
      $scriptPath = "c:\ebscripts\sync-to-s3.ps1"

      # Remove existing task if present
      $existing = Get-ScheduledTask -TaskName $taskName -ErrorAction SilentlyContinue
      if ($existing) {
        Unregister-ScheduledTask -TaskName $taskName -Confirm:$false
      }

      # Create trigger: every 1 hour, repeating indefinitely
      $trigger = New-ScheduledTaskTrigger -Once -At (Get-Date) -RepetitionInterval (New-TimeSpan -Hours 1)

      # Run as SYSTEM so it has access and picks up instance profile credentials
      $action = New-ScheduledTaskAction -Execute "powershell.exe" -Argument "-ExecutionPolicy Bypass -NoProfile -File `"$scriptPath`""
      $principal = New-ScheduledTaskPrincipal -UserId "SYSTEM" -LogonType ServiceAccount -RunLevel Highest
      $settings = New-ScheduledTaskSettingsSet -AllowStartIfOnBatteries -DontStopIfGoingOnBatteries -StartWhenAvailable

      Register-ScheduledTask -TaskName $taskName -Trigger $trigger -Action $action -Principal $principal -Settings $settings
      Write-Host "Scheduled task '$taskName' created: runs every 1 hour."

commands:
  01_extend_disk:
    command: powershell -ExecutionPolicy Bypass -NoProfile -Command "$size = (Get-PartitionSupportedSize -DriveLetter C); if ($size.SizeMax -gt (Get-Partition -DriveLetter C).Size) { Resize-Partition -DriveLetter C -Size $size.SizeMax; Write-Host 'Partition extended' } else { Write-Host 'Partition already at max' }"
    waitAfterCompletion: 0
  02_setup_scheduled_task:
    command: powershell -ExecutionPolicy Bypass -NoProfile -File "c:\\ebscripts\\setup-s3-backup-task.ps1"
    waitAfterCompletion: 0
  03_run_initial_backup:
    command: powershell -ExecutionPolicy Bypass -NoProfile -File "c:\\ebscripts\\sync-to-s3.ps1"
    waitAfterCompletion: 0
